{
  "name": "codex-dynamic-workflows-lab",
  "version": "0.1.0",
  "description": "Experimental Codex plugin for bounded local dynamic workflow orchestration.",
  "type": "module",
  "bin": {
    "codex-flow": "./dist/src/cli.js",
    "codex-flow-mcp": "./dist/src/mcp-server.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/build-plugin-bundle.js && node scripts/sync-marketplace-plugin.js",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:offline": "npm test",
    "lint": "npm run build && node --check dist/src/cli.js && node --check dist/src/mcp-server.js",
    "plugin:validate": "node scripts/validate-plugin.js",
    "check": "npm run lint && npm run test",
    "pack:dry": "npm pack --dry-run"
  },
  "files": [
    "dist/",
    "skills/",
    "examples/",
    ".codex-plugin/",
    ".agents/plugins/marketplace.json",
    "plugins/",
    ".mcp.json",
    "README.md",
    "RESULTATS.md"
  ],
  "dependencies": {
    "acorn": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "author": "Pezzos",
  "homepage": "https://github.com/pezzos/codex-dynamic-workflows-lab",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pezzos/codex-dynamic-workflows-lab.git"
  },
  "keywords": [
    "codex",
    "workflow",
    "orchestration",
    "mcp",
    "multi-agent"
  ]
}
